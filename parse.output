State 31 conflicts: 1 shift/reduce
State 59 conflicts: 1 shift/reduce
State 64 conflicts: 3 shift/reduce


Grammar

    0 $accept: program $end

    1 program: line
    2        | program '\n'
    3        | program '\n' line
    4        | program error '\n'

    5 @1: /* empty */

    6 line: NUMBER @1 statements

    7 statements: statement
    8           | statement ';' statements

    9 statement: /* empty */
   10          | ASK printlist
   11          | COMMENT
   12          | DO NUMBER
   13          | ERASE
   14          | ERASE ALL
   15          | ERASE NUMBER
   16          | MODIFY NUMBER
   17          | FOR variable '=' expression ',' expression
   18          | FOR variable '=' expression ',' expression ',' expression
   19          | GO
   20          | GOTO
   21          | GOTO NUMBER
   22          | IF '(' expression ')' NUMBER
   23          | IF '(' expression ')' NUMBER ',' NUMBER
   24          | IF '(' expression ')' NUMBER ',' NUMBER ',' NUMBER
   25          | LIBRARY CALL STRING
   26          | LIBRARY SAVE STRING
   27          | LIBRARY RUN STRING
   28          | QUIT
   29          | RETURN
   30          | SET variable '=' expression
   31          | TYPE printlist
   32          | TYPE '$'
   33          | WRITE
   34          | WRITE expression

   35 expression: expression2

   36 expression2: expression3
   37            | expression2 e2op expression3

   38 e2op: '+'
   39     | '-'

   40 expression3: expression4
   41            | expression3 term expression4

   42 term: '*'
   43     | '/'
   44     | '^'

   45 expression4: function
   46            | unary_op function

   47 unary_op: '-'

   48 function: factor
   49         | fn_0
   50         | fn_0 '(' ')'
   51         | fn_0 '[' ']'
   52         | fn_0 '<' '>'
   53         | fn_0 '(' expression ')'
   54         | fn_0 '[' expression ']'
   55         | fn_0 '<' expression '>'
   56         | fn_1 '(' expression ')'
   57         | fn_1 '[' expression ']'
   58         | fn_1 '<' expression '>'

   59 fn_0: FRAN
   60     | FIN

   61 fn_1: FABS
   62     | FADC
   63     | FATN
   64     | FCOM
   65     | FCOS
   66     | FEXP
   67     | FDIS
   68     | FDXS
   69     | FITR
   70     | FLOG
   71     | FNEW
   72     | FSQT
   73     | FSGN
   74     | FSIN
   75     | FOUT

   76 factor: NUMBER
   77       | NUMSTR
   78       | STRING
   79       | variable
   80       | '(' expression ')'
   81       | '[' expression ']'
   82       | '<' expression '>'

   83 variable: VARIABLE_NAME
   84         | VARIABLE_NAME '(' exprlist ')'

   85 printlist: expression
   86          | printlist expression
   87          | printsep
   88          | printlist printsep
   89          | FMTSTR
   90          | printlist FMTSTR
   91          | '%'
   92          | printlist '%'

   93 printsep: ','
   94         | '!'
   95         | '#'
   96         | ':'

   97 exprlist: expression
   98         | exprlist ',' expression


